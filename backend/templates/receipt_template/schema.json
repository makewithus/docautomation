{
  "type": "receipt",
  "label": "Receipt",
  "fields": [
    {"name": "receipt_number",   "type": "string",  "required": true,
     "note": "Format: RWC-2025-001"},
    {"name": "date",             "type": "string",  "required": true,
     "note": "DD/MM/YYYY"},
    {"name": "service_name",     "type": "string",  "required": true,
     "note": "Shown as 'For Service' — CAPS"},
    {"name": "payment_mode",     "type": "string",  "required": true,
     "note": "e.g. GOOGLE PAY, UPI, BANK TRANSFER, CASH"},
    {"name": "client_name",      "type": "string",  "required": true,
     "note": "Shown as 'Received From'"},
    {"name": "client_phone",     "type": "string",  "required": false},
    {"name": "amount_received",  "type": "string",  "required": true,
     "note": "Plain number with commas, no ₹ symbol"},
    {"name": "amount_in_words",  "type": "string",  "required": false,
     "note": "e.g. Fourteen Thousand only"},
    {"name": "balance",          "type": "string",  "required": false,
     "note": "Remaining amount owed after this payment"},
    {"name": "line_items",       "type": "array",   "required": true,
     "note": "Each item: { description, hours, unit_price, amount }"},
    {"name": "subtotal",         "type": "string",  "required": true},
    {"name": "gst_percent",      "type": "number",  "required": true,
     "note": "0 unless explicitly mentioned"},
    {"name": "gst_amount",       "type": "string",  "required": true},
    {"name": "total",            "type": "string",  "required": true},
    {"name": "payment_status",   "type": "string",  "required": false,
     "note": "PAID or UNPAID — controls red stamp"},
    {"name": "paid_on",          "type": "string",  "required": false,
     "note": "DD MONTH YYYY — only if payment_status is PAID"},
    {"name": "bank_name",        "type": "string",  "required": false,
     "note": "Default: SBI / UPI"},
    {"name": "upi_phone",        "type": "string",  "required": false},
    {"name": "upi_id",           "type": "string",  "required": false}
  ]
}